{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignore": ["docs/**", "examples/**", ".changeset/changelog.cjs"],
  "workspaces": {
    "packages/contracts": {
      "project": ["src/**/*.ts"]
    },
    "packages/core": {
      "project": ["src/**/*.ts"]
    },
    "packages/cli": {
      "project": ["src/**/*.ts"]
    },
    "packages/mcp": {
      "project": ["src/**/*.ts"]
    },
    "packages/playwright-plugin": {
      "project": ["src/**/*.ts"]
    },
    "packages/react": {
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    },
    "packages/runtime-intercept": {
      "project": ["src/**/*.ts"]
    },
    "packages/vitest-plugin": {
      "project": ["src/**/*.ts"]
    }
  }
}
