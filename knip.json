{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignore": ["examples/**"],
  "ignoreIssues": {
    "packages/**/src/**/*.ts": ["types"],
    "packages/**/src/**/*.tsx": ["types"]
  },
  "workspaces": {
    ".": {
      "entry": [
        "scripts/check-pack-integrity.mjs",
        "scripts/check-performance.mjs",
        "scripts/consumer-smoke-npm.mjs",
        "scripts/consumer-smoke-pack.mjs",
        "scripts/publish-packages.mjs"
      ],
      "project": ["scripts/**/*.mjs"]
    },
    "packages/contracts": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core": {
      "entry": ["src/index.ts", "src/browser.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/cli": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/mcp": {
      "entry": ["src/index.ts", "src/bin/mcp-stdio.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/playwright-plugin": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/react": {
      "entry": ["src/index.ts", "src/browser.ts"],
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    },
    "packages/runtime-intercept": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/vitest-plugin": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "e2e-tests": {
      "ignoreDependencies": [
        "@lunatest/cli",
        "@lunatest/mcp",
        "@lunatest/playwright-plugin"
      ],
      "project": ["*.test.ts"]
    }
  }
}
